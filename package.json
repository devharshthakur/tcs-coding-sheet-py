{
  "name": "tcs-coding-sheet-py",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "uv run ty check",
    "format:py": "uv format --preview-features format",
    "format:docs": "prettier --write .",
    "format": "pnpm run format:py && pnpm run format:docs",
    "precommit": "pnpm run lint && pnpm run format",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3"
  },
  "dependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260415.1",
    "tsx": "^4.21.0"
  }
}
